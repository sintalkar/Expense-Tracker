rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    // Hardcode an admin email for bootstrapping, plus typical claim checks.
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "V90369@gmail.com"
      );
    }
    function isBlocked() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBlocked == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Allow user to create their own profile, but they cannot bootstrap themselves as admin unless they are the root admin
      allow create: if isOwner(userId) && !isBlocked();
      
      // Allow user to update their doc as long as they don't touch protected flags
      allow update: if (
        isOwner(userId) && !isBlocked() &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'isBlocked']))
      ) || isAdmin();
      
      allow delete: if isAdmin();

      match /receipts/{receiptId} {
        allow read, write: if isOwner(userId) && !isBlocked();
        allow read, delete: if isAdmin();
      }

      match /transactions/{txId} {
        allow read, write: if isOwner(userId) && !isBlocked();
        allow read, delete: if isAdmin();
      }
    }

    match /admin_configs/{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /admin_audit_logs/{document=**} {
      allow read, write: if isAdmin();
    }

    match /public_config/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
